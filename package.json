{
  "name": "ps-spa",
  "version": "0.5.1",
  "description": "PureScript SPA library with file-based routing and a bundled CLI inspired by elm-spa",
  "license": "MIT",
  "author": "Michal Majchrzak",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-man-with-a-golden-mind/ps-spa.git"
  },
  "homepage": "https://github.com/the-man-with-a-golden-mind/ps-spa#readme",
  "bugs": {
    "url": "https://github.com/the-man-with-a-golden-mind/ps-spa/issues"
  },
  "bin": {
    "ps-spa": "./scripts/ps-spa.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "AGENTS.md",
    "LICENSE",
    "README.md",
    "llms.txt",
    "benchmarks",
    "docs",
    "packages.dhall",
    "spago.yaml",
    "scripts",
    "spago.dhall",
    "src"
  ],
  "keywords": [
    "library",
    "purescript",
    "spa",
    "routing",
    "elm-spa",
    "tea",
    "codegen",
    "vite"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "add": "node scripts/ps-spa.mjs --root examples/basic add",
    "bench": "node scripts/run-benchmarks.mjs --root examples/basic",
    "bench:browser": "node scripts/run-browser-bench.mjs --root examples/basic --open",
    "bench:browser:verify": "node scripts/run-browser-bench.mjs --root examples/basic --verify --open",
    "bench:verify": "node scripts/run-benchmarks.mjs --root examples/basic --verify",
    "bump:patch": "node scripts/ps-spa.mjs bump-version patch --tag",
    "bump:minor": "node scripts/ps-spa.mjs bump-version minor --tag",
    "bump:major": "node scripts/ps-spa.mjs bump-version major --tag",
    "doctor": "node scripts/ps-spa.mjs --root examples/basic doctor",
    "gen": "node scripts/ps-spa.mjs --root examples/basic gen",
    "new": "node scripts/ps-spa.mjs new",
    "prepublishOnly": "node scripts/release-check.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:patch": "npm run release:check && npm run bump:patch && npm publish",
    "release:minor": "npm run release:check && npm run bump:minor && npm publish",
    "release:major": "npm run release:check && npm run bump:major && npm publish",
    "test": "node --test \"tests-js/**/*.test.mjs\" && node scripts/test-purescript.mjs",
    "test:generated": "node --test \"examples/basic/tests-generated/**/*.test.mjs\"",
    "test:js": "node --test \"tests-js/**/*.test.mjs\"",
    "test:ps": "node scripts/test-purescript.mjs",
    "verify": "node scripts/ps-spa.mjs --root examples/basic verify"
  }
}
